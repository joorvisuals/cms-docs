{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ContentMaker",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "help/introduction",
              "help/quickstart",
              "help/concepts"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "help/features/knowledge-base",
              "help/features/clients",
              "help/features/credits",
              "help/features/timesheets"
            ]
          },
          {
            "group": "Account & Billing",
            "pages": [
              "help/account/settings",
              "help/account/billing",
              "help/account/team"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoints/articles",
              "api-reference/endpoints/clients",
              "api-reference/endpoints/credits"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.contentmaker.space",
          "icon": "browser"
        },
        {
          "anchor": "Website",
          "href": "https://contentmaker.space",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@contentmaker.space"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.contentmaker.space/signup"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://contentmaker.space"
    }
  }
}
